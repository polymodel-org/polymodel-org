{
  // wrangler is run via npx (or a globally installed wrangler); no local
  // devDependency, so the editor "$schema" line is intentionally omitted.
  "name": "polymodel-org",
  "compatibility_date": "2026-06-16",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public"
  }
}
